{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HardView",
  "version": "1.0.0",
  "identifier": "io.hardview.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "HardView — Hardware-Inventar",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: https://ipc.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "HardView",
    "category": "Utility",
    "shortDescription": "Hardware-Inventar & Asset-Zuordnung",
    "longDescription": "HardView zeigt den Hardware-Bestand (CPU, RAM, Alter, SSD/HDD) aller Arbeitsplätze, kennzeichnet Upgrade-Kandidaten und ordnet PCs den AD-Benutzern zu."
  }
}
